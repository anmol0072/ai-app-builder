generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Stores the JSON configurations that define dynamic tables, forms, and routes
model AppConfiguration {
  id        String   @id @default(uuid())
  name      String   @unique
  schema    Json     // The structure defining the UI, APIs, and DB columns
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  records   DynamicRecord[]
}

// A flexible table to store dynamic records based on the AppConfiguration
model DynamicRecord {
  id              String   @id @default(uuid())
  configurationId String
  userId          String?  // For user-scoped data access
  data            Json     // The actual record data mapping to the schema
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  configuration   AppConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
}

// Basic User model for Authentication
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
